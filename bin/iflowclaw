#!/bin/bash

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
PROJECT_ROOT="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"
PID_FILE="$PROJECT_ROOT/data/iflowclaw.pid"
LOG_FILE="$PROJECT_ROOT/logs/iflowclaw.log"
ENV_FILE="$PROJECT_ROOT/.env"
STATE_FILE="$PROJECT_ROOT/data/.container_state"
FINGERPRINT_FILES="$PROJECT_ROOT/container/Dockerfile $PROJECT_ROOT/container/entrypoint.sh $PROJECT_ROOT/package.json $PROJECT_ROOT/package-lock.json"

check_node() {
    if ! command -v node >/dev/null; then
        echo "❌ 需要安装 Node.js 20+"
        exit 1
    fi
    local ver=$(node -v | cut -d. -f1 | tr -d v)
    if [ "$ver" -lt 20 ]; then
        echo "❌ Node.js 版本需要 20+"
        exit 1
    fi
}

check_env() {
    if [ ! -f "$ENV_FILE" ]; then
        echo "❌ 配置文件不存在，请先运行: iflowclaw setup"
        return 1
    fi
    if ! grep -q "FEISHU_APP_ID=" "$ENV_FILE" || ! grep -q "FEISHU_APP_SECRET=" "$ENV_FILE"; then
        echo "❌ 配置不完整，请先运行: iflowclaw setup"
        return 1
    fi
}

has_container() { command -v docker >/dev/null 2>&1 || command -v podman >/dev/null 2>&1; }

image_exists() { [ -n "$(docker images -q iflow-agent:latest 2>/dev/null)" ]; }

get_fingerprint() { cat $FINGERPRINT_FILES 2>/dev/null | md5sum | cut -d' ' -f1; }

is_systemd() { systemctl --user list-unit-files iflowclaw.service 2>/dev/null | grep -q "iflowclaw"; }

is_pm2() { command -v pm2 >/dev/null 2>&1 && pm2 describe iflowclaw >/dev/null 2>&1; }

build_project() {
    if [ -d "$PROJECT_ROOT/dist" ] && [ "$(find "$PROJECT_ROOT/src" -newer "$PROJECT_ROOT/dist" -type f 2>/dev/null | wc -l)" -eq 0 ]; then
        return
    fi
    echo "🔨 构建项目..."
    cd "$PROJECT_ROOT" && npm run build >/dev/null 2>&1 && echo "✓ 完成"
}

build_container() {
    if ! has_container; then
        echo "💡 无容器运行时，使用主机模式"
        return
    fi
    local fp=$(get_fingerprint) last=""
    [ -f "$STATE_FILE" ] && last=$(cat "$STATE_FILE")
    if [ "${1:-}" != "force" ] && image_exists && [ "$fp" = "$last" ]; then
        echo "✅ 镜像已是最新"
        return
    fi
    echo "📦 构建容器镜像..."
    cd "$PROJECT_ROOT" && bash container/build.sh latest --no-build ${1:+--no-cache} >/dev/null 2>&1
    echo "$fp" > "$STATE_FILE" && echo "✓ 完成"
}

start_service() {
    check_node || exit 1
    check_env || exit 1
    build_project
    build_container
    mkdir -p "$PROJECT_ROOT/logs" "$PROJECT_ROOT/data"

    if is_systemd; then
        systemctl --user start iflowclaw
        echo "✓ 已启动 (systemd)"
        return
    fi
    if is_pm2; then
        pm2 start iflowclaw
        echo "✓ 已启动 (PM2)"
        return
    fi

    if [ -f "$PID_FILE" ] && kill -0 $(cat "$PID_FILE") 2>/dev/null; then
        echo "⚠️  已在运行"
        return
    fi
    
    echo "🚀 启动 iFlowClaw..."
    cd "$PROJECT_ROOT" && nohup node dist/index.js >> "$LOG_FILE" 2>&1 &
    echo $! > "$PID_FILE"
    sleep 2
    
    if kill -0 $(cat "$PID_FILE") 2>/dev/null; then
        echo "✓ 已启动 (PID: $(cat $PID_FILE))"
        echo "  日志: tail -f $LOG_FILE"
    else
        echo "❌ 启动失败，请检查日志: $LOG_FILE"
        rm -f "$PID_FILE"
        exit 1
    fi
}

stop_service() {
    if is_systemd; then
        systemctl --user stop iflowclaw
        # 清理残留容器
        has_container && docker rm -f $(docker ps -aq --filter "name=iflow-") 2>/dev/null || true
        echo "✓ 已停止"
        return
    fi
    if is_pm2; then
        pm2 stop iflowclaw
        has_container && docker rm -f $(docker ps -aq --filter "name=iflow-") 2>/dev/null || true
        echo "✓ 已停止"
        return
    fi
    if [ -f "$PID_FILE" ]; then
        kill $(cat "$PID_FILE") 2>/dev/null
        rm -f "$PID_FILE"
        # 清理残留容器
        has_container && docker rm -f $(docker ps -aq --filter "name=iflow-") 2>/dev/null || true
        echo "✓ 已停止"
        return
    fi
    local p=$(pgrep -f "node dist/index.js")
    if [ -n "$p" ]; then
        kill $p 2>/dev/null
        has_container && docker rm -f $(docker ps -aq --filter "name=iflow-") 2>/dev/null || true
        echo "✓ 已停止"
    else
        echo "⚠️  未运行"
    fi
}

show_status() {
    local status
    if is_systemd; then
        status=$(systemctl --user is-active iflowclaw 2>/dev/null)
    elif is_pm2; then
        status=$(pm2 describe iflowclaw 2>/dev/null | grep status | awk '{print $4}')
    elif [ -f "$PID_FILE" ] && kill -0 $(cat "$PID_FILE") 2>/dev/null; then
        status="运行中"
    else
        status="已停止"
    fi
    echo "服务: $status"
    
    local container_status
    if has_container; then
        if image_exists; then
            container_status="✅ 已就绪"
        else
            container_status="❌ 未构建"
        fi
    else
        container_status="💡 主机模式"
    fi
    echo "容器: $container_status"
}

run_foreground() {
    check_node || exit 1
    check_env || exit 1
    mkdir -p "$PROJECT_ROOT/logs" "$PROJECT_ROOT/data"
    build_project
    echo "🚀 启动 iFlowClaw (前台模式)..."
    cd "$PROJECT_ROOT" && exec node dist/index.js
}

setup_wizard() {
    if check_env; then
        echo "⚠️  配置已存在，是否重新配置？(y/N)"
        read r
        [[ ! "$r" =~ ^[Yy]$ ]] && return
    fi
    echo "📋 飞书应用配置: https://open.feishu.cn/app"
    read -p "App ID: " id
    read -p "App Secret: " secret
    read -p "机器人名称 [iFlow]: " name
    cat > "$ENV_FILE" <<EOF
ASSISTANT_NAME=${name:-iFlow}
FEISHU_APP_ID=$id
FEISHU_APP_SECRET=$secret
LOG_LEVEL=info
EOF
    echo "✓ 配置已保存"
    build_project
    build_container
    echo ""
    echo "下一步: iflow login && iflowclaw start"
}

setup_systemd() {
    mkdir -p "$HOME/.config/systemd/user"
    sed "s|{{USER}}|$(whoami)|g; s|{{PROJECT_ROOT}}|$PROJECT_ROOT|g; s|{{IFLOWCLAW_BIN_RUN_CMD}}|$PROJECT_ROOT/bin/iflowclaw run|g" \
        "$PROJECT_ROOT/iflowclaw.service.template" > "$HOME/.config/systemd/user/iflowclaw.service"
    systemctl --user daemon-reload
    echo "✓ 已安装"
    echo "启用: systemctl --user enable --now iflowclaw"
}

case "${1:-}" in
    setup)     setup_wizard ;;
    start)     start_service ;;
    stop)      stop_service ;;
    restart)   stop_service; sleep 1; start_service ;;
    status)    show_status ;;
    logs)      tail -f "$LOG_FILE" ;;
    run)       run_foreground ;;
    build)     build_project; build_container ;;
    build-image) build_container force ;;
    setup-systemd) setup_systemd ;;
    *) cat <<EOF
iFlowClaw 管理工具

命令: setup | start | stop | restart | status | logs | run | build | build-image | setup-systemd

快速开始:
  1. iflowclaw setup    # 配置
  2. iflow login        # 认证
  3. iflowclaw start    # 启动
EOF
esac