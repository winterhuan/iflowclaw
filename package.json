{
  "name": "iflowclaw",
  "version": "1.0.0",
  "description": "A lightweight, secure personal AI assistant using iFlow platform with container isolation",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.ts",
    "container:build": "cd container && ./build.sh"
  },
  "keywords": ["ai", "assistant", "iflow", "container", "whatsapp", "telegram"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.6.0",
    "cron-parser": "^4.9.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": { "node": ">=20.0.0" }
}
