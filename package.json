{
  "name": "iflowclaw",
  "version": "1.0.0",
  "description": "A lightweight personal AI assistant using iFlow platform",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "iflowclaw": "./bin/iflowclaw"
  },
  "scripts": {
    "build": "tsc",
    "start": "bash bin/iflowclaw start",
    "dev": "tsx src/index.ts",
    "dev:watch": "tsx watch src/index.ts",
    "setup": "bash bin/iflowclaw setup",
    "stop": "bash bin/iflowclaw stop",
    "status": "bash bin/iflowclaw status",
    "logs": "bash bin/iflowclaw logs",
    "restart": "bash bin/iflowclaw restart",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "REAL_TEST=true vitest run test/integration.test.ts"
  },
  "keywords": [
    "ai",
    "assistant",
    "iflow",
    "feishu"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@iflow-ai/iflow-cli-sdk": "0.2.2",
    "@larksuiteoapi/node-sdk": "^1.43.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^11.6.0",
    "cron-parser": "^5.5.0",
    "dotenv": "^17.3.1",
    "openai": "^6.27.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
