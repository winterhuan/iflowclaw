# iFlowClaw Configuration
# Copy this file to .env and fill in your values

# Assistant name (used for @mentions)
ASSISTANT_NAME=iFlow

# ===========================================
# Feishu (Lark) Channel Configuration
# ===========================================
# Get your credentials from: https://open.feishu.cn/app
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===========================================
# Authentication
# ===========================================

# iFlow CLI OAuth Login (REQUIRED)
# Run `iflow login` to authenticate. The SDK will automatically use
# credentials from ~/.iflow/settings.json. No configuration needed here!

# ===========================================
# Agent Configuration
# ===========================================
AGENT_TIMEOUT=1800000
IDLE_TIMEOUT=1800000

# Logging
LOG_LEVEL=info
# ===========================================
# Embedding Configuration (for semantic memory)
# ===========================================
# Get your API key from: https://build.nvidia.com/explore/embedding
EMBEDDING_API_KEY=your-nvidia-api-key-here
EMBEDDING_BASE_URL=https://integrate.api.nvidia.com/v1
EMBEDDING_MODEL=baai/bge-m3
