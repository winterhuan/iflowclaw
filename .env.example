# iFlowClaw Configuration
# Copy this file to .env and fill in your values

# Assistant name (used for @mentions)
ASSISTANT_NAME=iFlow

# ===========================================
# Authentication (Choose ONE method)
# ===========================================

# Method 1: Use existing iFlow CLI login (RECOMMENDED)
# If you have already logged in with `iflow login`, 
# the SDK will automatically use those credentials.
# No configuration needed - just leave IFLOW_API_KEY empty!

# Method 2: API Key (for servers/headless environments)
# Get your API key from: https://platform.iflow.cn
# IFLOW_API_KEY=your-api-key-here
# IFLOW_BASE_URL=https://apis.iflow.cn/v1
# IFLOW_MODEL_NAME=Qwen3-Coder

# ===========================================
# Container Configuration
# ===========================================
CONTAINER_IMAGE=iflowclaw-agent:latest
CONTAINER_TIMEOUT=1800000
IDLE_TIMEOUT=1800000
MAX_CONCURRENT_CONTAINERS=5

# Logging
LOG_LEVEL=info
