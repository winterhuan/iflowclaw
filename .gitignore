# iFlow CLI config - keep skills but ignore other state
.iflow/*
!.iflow/skills/
**/.iflow/*
!**/.iflow/skills/

# Groups - keep AGENTS.md and .iflow/, ignore everything else
# First ignore all content in group directories
groups/*/*
# Then exclude what we want to keep
!groups/*/AGENTS.md
!groups/*/.iflow
!groups/*/.iflow/**
